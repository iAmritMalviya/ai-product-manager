NODE_ENV=development

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# Database
DATABASE_URL=postgresql://supercfo:supercfo@localhost:5433/supercfo

# Redis
REDIS_URL=redis://localhost:6379

# AI Provider: "openai" | "gemini" (default: gemini)
AI_PROVIDER=gemini

# Required if AI_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key

# Required if AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key

# Optional: override the default model for the chosen provider
# Defaults: openai=gpt-4o-mini, gemini=gemini-2.0-flash
# GEMINI_AI_PROVIDER_MODEL_NAME=gemini-2.0-flash

# HTTP Server
PORT=3000
